# NanoClaw / Okti configuration
# Copy this file to .env and fill in your values.

ASSISTANT_NAME=Okti

# --- Model / API ---
# Option A: Anthropic API directly
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: Ollama or compatible proxy (default)
ANTHROPIC_BASE_URL=http://127.0.0.1:11434/v1
ANTHROPIC_MODEL=llama3
ANTHROPIC_API_KEY=ollama-placeholder

# Credential proxy port (default: 3001)
CREDENTIAL_PROXY_PORT=3001

# --- Vault ---
# Path to your Obsidian vault (nanoclaw subfolder).
# The vault is synced separately and must exist before starting.
VAULT_PATH=/path/to/your/obsidian-vault/nanoclaw/

# --- Channels ---
# Telegram (required for Telegram channel)
TELEGRAM_BOT_TOKEN=

# WhatsApp (required for WhatsApp channel)
# No token needed — QR code auth at first start
